# AI Model API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Data Sources
NEWS_API_KEY=your_newsapi_key_here

# Database (optional, defaults to aip.db in backend dir)
DB_PATH=aip.db

# Frontend (set in frontend/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Agent configuration (all agents use gpt-5.4 via OPENAI_API_KEY)
# Scheduled jobs run automatically on startup:
#   Orchestrator : daily briefing @ 09:00, status every 60 min
#   Marketing    : daily teaser @ 08:30, lead nurture every 2 h
#   Market Intel : pre-market @ 07:00, close summary @ 16:30
#   Customer     : daily check @ 10:00
#   Analytics    : KPI report @ 08:00, anomaly check every 4 h
